# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EXTERNAL_API_URL: The endpoint for the image generation API.
EXTERNAL_API_URL="https://grsai.dakka.com.cn/v1/api/generate"

# EXTERNAL_API_KEY: Your API key for the image generation API.
# Obtain from: https://grsai.ai/zh/dashboard/api-keys
EXTERNAL_API_KEY="sk-xxxxxxxxxxx"
